package MiniProject;
import java.util.*;
abstract class VehicleService //abstract class
{
	String customername;  
	String vehiclenumber;
	String servicetype;
	VehicleService(String customername,String vehiclenumber,String servicetype) //constructor
	{
		this.customername=customername;
		this.vehiclenumber=vehiclenumber;
		this.servicetype=servicetype;
	}
	abstract double calculateServiceCharge(); //abstract method
	    void displayServiceDetails() //concrete method
	    {
	    	System.out.println("customername: "+customername); //method display panna use agum
	    	System.out.println("vehiclenumber: "+vehiclenumber);
	    	System.out.println("servicetype: "+servicetype);
	    	
	    	}
}
class CarService extends VehicleService //child class1
{
	double sparePartsCost; //variable use pandrom
	CarService(String customername,String vehiclenumber,String servicetype,double sparePartsCost)  //constructor
	{
		super(customername,vehiclenumber,servicetype);  //parent class members ah access panna use pandrom
		this.sparePartsCost=sparePartsCost;  //this. use panna value confuse agama irukum
	}
	double calculateServiceCharge()  //abstract method la override pandrom
	{
		double serviceCharge = 2000+sparePartsCost; //calculate the charge
		
		displayServiceDetails();   //display use panna kandipa return use pannanum illa ah error varum
		System.out.println("sparePartsCost: "+sparePartsCost);
    	System.out.println("serviceCharge: "+serviceCharge);
		return serviceCharge;
	}
}
class BikeService extends VehicleService //child class2
{
	double sparePartsCost;
	BikeService(String customername,String vehiclenumber,String servicetype,double sparePartsCost)  //constructor
	{
		super(customername,vehiclenumber,servicetype);  //parent class members ah access panna use pandrom-
		this.sparePartsCost=sparePartsCost; //this. use panna value confuse agama irukum
	}
	double calculateServiceCharge()   //abstract method la override pandrom
	{
		double serviceCharge = 800+sparePartsCost;   //calculate the charge
		displayServiceDetails(); //display use panna kandipa return use pannanum illa ah error varum
		System.out.println("sparePartsCost: "+sparePartsCost);
    	System.out.println("serviceCharge: "+serviceCharge);
    	return serviceCharge;
	}
}
public class Project1VehicleServiceSystemUsingAbstraction {
	public static void main(String[] args) {
		VehicleService v;  //reference Variable   //Downcasting use pandrom, object use pannalaa 
		v=new CarService("Mythili","TN10AB1234","Normal Service",3500.0);
		v.calculateServiceCharge();
		v=new BikeService("Prasanth","TN10AB1234","Oil Service",1200.0);
        v.calculateServiceCharge();
	}
}
